PORT=8080
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: shared app id so only museeum-web can call this API (set same value as VITE_MUSEEUM_APP_ID in frontend)
# MUSEEUM_APP_ID=your-secret-app-id
# Optional: judge/access code so only people with this code can use the app (e.g. hackathon judges)
# JUDGE_ACCESS_CODE=your-judge-code
# Optional: override Live model (e.g. gemini-2.0-flash-exp if 2.5 is unavailable)
# GEMINI_LIVE_MODEL=gemini-2.0-flash-exp
