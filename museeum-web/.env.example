# Backend API URL (used at build time for production; for local dev, use when you run the backend on another port)
# Default if unset: http://localhost:8080
VITE_API_URL=http://localhost:8080

# Shared app id (must match museeum-api MUSEEUM_APP_ID). If set, only this app can call the API.
# VITE_MUSEEUM_APP_ID=your-secret-app-id